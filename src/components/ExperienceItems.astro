---
const {title, position, url, startDate, endDate,  description = [] } = Astro.props;

---

<div class="experience-item">
    <div class="dot"></div>
    <div class="header-container">
        <div>
            {url ? (
                <a href={url} target="_blank" rel="noopener noreferrer">
                    <h3>{title}</h3>
                </a>
            ) : (
                <h3>{title}</h3>
            )}
            <h4>{position}</h4>
        </div>
        <time>{endDate ? `${startDate} - ${endDate}` : startDate}</time>
    </div>
    <p set:html={description}></p>
</div>
 

<style>
    .experience-item {
        position: relative;
        padding: 25px 0;
    }
    
    .dot {
        position: absolute;
        width: 0.75rem;
        height: 0.75rem;
        background-image: linear-gradient(225deg, #eb6904 50%, #784BA0 50%);
        transform: scale(1.1);
        border-radius: 50%;       
        left: -47px;
        margin-top: 0.375rem;
    }
    
    .header-container{
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-direction: column;
        margin-bottom: 4px;
    }

    time {
        padding-bottom: 0.35rem;
        font-size: 0.875rem;
        color: #bababa;
    }
    
    h3, h4 {
        font-weight: 600;
        color: #f9fafb;
        padding-bottom: 0.30rem;
    }

    h3 {
        font-size: 1.5rem;
        color: #eb6904;
    }

    h4{
        font-weight: normal;
    }
    
    p {
        color: #d1d5db; 
    }

    a:hover{
        text-decoration: none;
        cursor: pointer;
    }

    .header-container a{
        text-decoration: none;
        display: inline-block;
    }

    .header-container a h3{
        position: relative;
        display: inline-block;
        transition: color 0.25s ease, transform 0.25s ease;
    }

    .header-container a h3::after{
        content: "";
        position: absolute;
        left: 0;
        bottom: 2px;
        width: 100%;
        height: 2px;
        background-image: linear-gradient(90deg, #eb6904, #784BA0);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
    }

    .header-container a:hover h3{
        color: #ffb020;
        transform: translateY(-2px);
    }

    .header-container a:hover h3::after{
        transform: scaleX(1);
    }

    p :global(.paycargo-link){
        color: #eb6904;
        font-weight: 700;
        text-decoration: none;
        border-bottom: 2px solid rgba(235, 105, 4, 0.45);
        padding-bottom: 1px;
        white-space: nowrap;
        transition: color 0.25s ease, border-color 0.25s ease;
    }

    p :global(.paycargo-link::after){
        content: "↗";
        font-size: 0.8em;
        margin-left: 3px;
        display: inline-block;
        transition: transform 0.25s ease;
    }

    p :global(.paycargo-link:hover){
        color: #ffb020;
        border-color: #ffb020;
    }

    p :global(.paycargo-link:hover::after){
        transform: translate(2px, -2px);
    }

    
    body.open .dot, body.open time, body.open h3, body.open h4, body.open p,  body.open a {
        display: none;
   }


    
</style>