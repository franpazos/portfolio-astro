---
import SocialButtons from "@/components/SocialButtons.astro"
---

<section id="hero" class="hero">
  <div class="background">
    <div class="aurora" aria-hidden="true">
      <span class="blob blob-1"></span>
      <span class="blob blob-2"></span>
      <span class="blob blob-3"></span>
    </div>
    <div class="grid-overlay" aria-hidden="true"></div>
    <div class="spotlight" aria-hidden="true"></div>

    <div class="container-title">
        <h1>Fran Pazos</h1>
        <h2><span class="role" id="role">Software Engineer</span><span class="type-cursor" aria-hidden="true">|</span></h2>
        <SocialButtons class="social-buttons" />
    </div>
    <div class="cv-container">
        <a href="/Assets/CV_Fran-Pazos_2024.pdf" target="_blank">Download CV</a>
    </div>
    </div>
</section>

<script type="module">
    import { gsap } from 'https://cdn.skypack.dev/gsap';

    function initAnimation() {
      gsap.set(['h1', 'h2', '.social-buttons', '.cv-container'], { y: 60, opacity: 0 });
      gsap.to(['h1', 'h2', '.social-buttons', '.cv-container'], {
        opacity: 1,
        y: 0,
        ease: 'power3.out',
        duration: 1.6,
        stagger: 0.2,
        delay: 0.2,
      });
    }

    function initRoleRotator() {
      const el = document.getElementById('role');
      if (!el) return;
      const roles = ['Software Engineer', 'Full-Stack Developer', 'Fintech @ PayCargo'];
      let ri = 0, ci = roles[0].length, deleting = true;
      function tick() {
        const word = roles[ri];
        if (deleting) {
          el.textContent = word.slice(0, --ci);
          if (ci === 0) { deleting = false; ri = (ri + 1) % roles.length; return setTimeout(tick, 400); }
        } else {
          el.textContent = word.slice(0, ++ci);
          if (ci === word.length) { deleting = true; return setTimeout(tick, 1800); }
        }
        setTimeout(tick, deleting ? 45 : 85);
      }
      setTimeout(tick, 2200);
    }

    function initInteractions() {
      const hero = document.getElementById('hero');
      if (!hero) return;
      const aurora = hero.querySelector('.aurora');
      let mouseX = 0, mouseY = 0, scrollY = 0;
      const apply = () => {
        if (aurora) aurora.style.transform = `translate3d(${mouseX}px, ${mouseY + scrollY}px, 0)`;
      };

      if (!window.matchMedia('(pointer: coarse)').matches) {
        hero.addEventListener('pointermove', (e) => {
          const r = hero.getBoundingClientRect();
          const rx = (e.clientX - r.left) / r.width;
          const ry = (e.clientY - r.top) / r.height;
          // spotlight follows the cursor
          hero.style.setProperty('--mx', (rx * 100) + '%');
          hero.style.setProperty('--my', (ry * 100) + '%');
          // aurora drifts subtly against the cursor (depth)
          mouseX = (rx - 0.5) * -30;
          mouseY = (ry - 0.5) * -30;
          apply();
        });
      }

      // scroll parallax: aurora lags behind the page for a "fixed" feel
      window.addEventListener('scroll', () => {
        scrollY = window.scrollY * 0.45;
        apply();
      }, { passive: true });
    }

    function init() { initAnimation(); initRoleRotator(); initInteractions(); }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
</script>

<style>
    .hero {
        position: relative;
        width: 100%;
        height: 100vh;
    }

    .background {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        position: relative;
        width: 100%;
        height: 100vh;
        background-color: #0b0c11;
    }

    /* Aurora blobs */
    .aurora {
        position: absolute;
        inset: -20%;
        z-index: 0;
        will-change: transform;
    }

    .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.7;
        mix-blend-mode: screen;
        will-change: transform;
    }

    .blob-1 {
        width: 52vw;
        height: 52vw;
        background: radial-gradient(circle, #ff7a12, transparent 66%);
        top: -8%;
        left: -6%;
        animation: drift1 16s ease-in-out infinite;
    }

    .blob-2 {
        width: 48vw;
        height: 48vw;
        background: radial-gradient(circle, #8b53c7, transparent 66%);
        bottom: -10%;
        right: -6%;
        animation: drift2 20s ease-in-out infinite;
    }

    .blob-3 {
        width: 40vw;
        height: 40vw;
        background: radial-gradient(circle, #2f8fd6, transparent 66%);
        top: 22%;
        left: 32%;
        opacity: 0.5;
        animation: drift3 18s ease-in-out infinite;
    }

    @keyframes drift1 {
        0%   { transform: translate(-6%, -4%) scale(1); }
        33%  { transform: translate(34%, 22%) scale(1.25); }
        66%  { transform: translate(14%, 46%) scale(1.1); }
        100% { transform: translate(-6%, -4%) scale(1); }
    }
    @keyframes drift2 {
        0%   { transform: translate(0, 0) scale(1); }
        33%  { transform: translate(-30%, -18%) scale(1.2); }
        66%  { transform: translate(-46%, 14%) scale(1.05); }
        100% { transform: translate(0, 0) scale(1); }
    }
    @keyframes drift3 {
        0%   { transform: translate(0, 0) scale(1); }
        33%  { transform: translate(-24%, 30%) scale(1.3); }
        66%  { transform: translate(28%, -22%) scale(1.12); }
        100% { transform: translate(0, 0) scale(1); }
    }

    /* Faint grid, faded towards the edges */
    .grid-overlay {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
        background-size: 44px 44px;
        -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
        mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    }

    /* Orange spotlight that follows the cursor */
    .spotlight {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: radial-gradient(circle 500px at var(--mx, 50%) var(--my, 50%), rgba(235, 105, 4, 0.16), transparent 55%);
    }

    .container-title {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        position: relative;
        z-index: 2;
        padding: 10px;
    }

    h1 {
        font-size: 4rem;
        font-weight: 800;
        background-color: #eb6904;
        background-image: linear-gradient(225deg, #ebb504 10%, #eb6904 70%, #eb6904 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        transition: all .2s;
    }

    h2 {
        font-size: 2.5rem;
        font-weight: 800;
        min-height: 1.2em;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .role {
        background-image: linear-gradient(225deg, #eb3e04 10%, #eb7b04 70%, #ebb504 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .type-cursor {
        color: #eb6904;
        -webkit-text-fill-color: #eb6904;
        font-weight: 400;
        margin-left: 2px;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink { 50% { opacity: 0; } }

    body.open h1, body.open h2, body.open .social-buttons {
        display: none;
    }

    .cv-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px 0 0 0;
        position: relative;
        z-index: 2;
    }

    .cv-container a {
        width: 150px;
        text-align: center;
        color: #13151a;
        font-weight: 800;
        text-decoration: none;
        background-color: #eb6904;
        padding: 15px;
        border-radius: 20px;
        cursor: pointer;
        box-shadow: rgba(138, 137, 137, 0.405) 0px 5px 15px 0px;
        transition: background-color 0.3s ease, transform 0.3s ease, background-image 0.3s ease;
    }

    .cv-container a:hover {
        background-image: linear-gradient(225deg, #ebb504 0%, #eb6904 50%, #784BA0 100%);
        transform: scale(1.1);
        color: #ffffff;
    }

    @media(min-width:768px) {
        h1 {
            font-size: 5rem;
            letter-spacing: -3px;
        }
        h2 {
            font-size: 3rem;
        }
    }

    @media(min-width:1024px) {
        h1 {
            font-size: 8rem;
            letter-spacing: -4px;
        }
        h2 {
            font-size: 3.5rem;
        }
    }
</style>
